{
  "name": "manthan-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "dev": "concurrently -n frontend,backend -c magenta,cyan \"npm run dev:frontend\" \"npm run dev:backend\"",
    "lint": "npm run lint --workspace frontend && npm run lint --workspace backend",
    "test": "npm run test --workspace backend",
    "build": "npm run build --workspace frontend && npm run build --workspace backend",
    "start": "npm run start --workspace backend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "prisma:deploy": "npm run prisma:deploy --workspace backend",
    "seed": "npm run seed --workspace backend",
    "db:seed": "npm run db:seed --workspace backend",
    "db:reset": "npm run db:reset --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
